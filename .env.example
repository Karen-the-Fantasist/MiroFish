# ===== Neo4j 图数据库配置 =====
NEO4J_PASSWORD=your_neo4j_password

# ===== LLM API 配置 =====
# 支持任意 OpenAI SDK 格式的 LLM API
# 推荐使用阿里百炼平台 qwen-plus 模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于 40 轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Embedding 配置（本地 vllm，可选）=====
EMBEDDING_MODEL=/path/to/your/embedding/model
EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
EMBEDDING_API_KEY=EMPTY

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env 文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== 已弃用 =====
# ZEP_API_KEY=your_zep_api_key_here  # 已迁移到 mem0 + Neo4j，不再需要
